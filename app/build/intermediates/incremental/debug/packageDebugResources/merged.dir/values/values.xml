<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg_dark">#121212</color>
    <color name="black">#000000</color>
    <color name="error_red">#CF6679</color>
    <color name="primary_accent">#03DAC6</color>
    <color name="surface_dark">#1E1E1E</color>
    <color name="surface_variant">#2C2C2C</color>
    <color name="text_high_emphasis">#FFFFFF</color>
    <color name="text_medium_emphasis">#B0B0B0</color>
    <color name="text_secondary">#B0B0B0</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">Ventas Maxi Pro</string>
    <style name="CustomDialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/surface_dark</item>
